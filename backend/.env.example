# Backend
PORT=3000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_HOST=unix:///var/run/docker.sock

# OpenAI (para chat de IA)
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4

# Ou use Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Escolha IA: 'openai' ou 'ollama'
AI_PROVIDER=openai

# Redis (opcional)
REDIS_URL=redis://localhost:6379

# PostgreSQL (opcional)
DATABASE_URL=postgresql://user:password@localhost:5432/sistem_agent

# ========================================
# ERROR MONITORING - Monitoramento de Erros
# ========================================
# URL do servidor de monitoramento (sem a / no final)
# Exemplo: http://192.168.1.108:3002
ERROR_MONITOR_URL=http://192.168.1.108:3002

# Nome da aplicação (para identificação)
APP_NAME=sistem-agent

# Versão da aplicação
APP_VERSION=1.0.0