# Sistem-Agent - Variáveis de Ambiente

# ==========================================
# Configurações Gerais
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# Frontend
# ==========================================
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ==========================================
# Docker
# ==========================================
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Windows: DOCKER_HOST=tcp://localhost:2375
# Linux/Mac: DOCKER_HOST=unix:///var/run/docker.sock

# ==========================================
# AI - OpenAI
# ==========================================
AI_PROVIDER=openai
OPENAI_API_KEY=sk-sua-chave-aqui-aqui
OPENAI_MODEL=gpt-4

# ==========================================
# AI - Ollama (local)
# ==========================================
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# ==========================================
# Error Monitoring - Monitoramento de Erros
# ==========================================
# URL do servidor de monitoramento de erros
# Para desenvolvimento local: http://localhost:3002
# Para servidor: http://192.168.1.108:3002
ERROR_MONITOR_URL=http://192.168.1.108:3002

# Nome da aplicação
APP_NAME=sistem-agent

# Versão da aplicação
APP_VERSION=1.0.0