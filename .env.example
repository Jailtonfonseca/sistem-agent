# Sistem-Agent - Variáveis de Ambiente

# ==========================================
# Configurações Gerais
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# Frontend
# ==========================================
FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ==========================================
# Docker
# ==========================================
DOCKER_SOCKET_PATH=/var/run/docker.sock

# ==========================================
# AI - OpenAI
# ==========================================
AI_PROVIDER=openai
OPENAI_API_KEY=sk-sua-chave-aqui-aqui
OPENAI_MODEL=gpt-4

# ==========================================
# AI - Ollama (local)
# ==========================================
# AI_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama2

# ==========================================
# GitHub Issue Auto-Creation
# ==========================================
# Configuração para criar issues automaticamente no GitHub quando ocorrerem erros

# Repo no formato "usuário/repositório"
GITHUB_REPO=Jailtonfonseca/sistem-agent

# Token GitHub com permissão para criar issues
# Gere em: https://github.com/settings/tokens
# Escopo necessário: repo (完整控制)
GITHUB_TOKEN=ghp_seu_token_aqui

# Labels para as issues criadas
ISSUE_LABELS=bug,auto-reported,erro-detectado

# Nome da aplicação (usado no título da issue)
APP_NAME=sistem-agent

# Versão da aplicação
APP_VERSION=1.0.0

# ==========================================
# Error Monitor (alternativo ao GitHub)
# ==========================================
# URL do servidor de monitoramento de erros (para desenvolvimento)
# ERROR_MONITOR_URL=http://localhost:3002
